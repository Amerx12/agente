# Variables de entorno para AmershOp - Agente IA Corporativo
# Copia este archivo como .env y configura los valores

# --- API Key de Google Gemini (REQUERIDO) ---
# Obtén tu API Key gratuita en: https://aistudio.google.com/
GOOGLE_API_KEY=tu_api_key_aqui

# --- Configuración de la Tienda ---
STORE_NAME=AmershOp

# --- Modelo LLM ---
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/embedding-001
LLM_TEMPERATURE=0.3

# --- Vector Store ---
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=amershop_docs
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SEARCH_K=5

# --- Directorio de Documentos ---
DOCUMENTS_DIR=./documents

# --- Credenciales de Usuarios ---
# Cambia estas contraseñas en producción
ADMIN_PASSWORD=amershop2024
USER1_PASSWORD=collab001
USER2_PASSWORD=collab002
RRHH_PASSWORD=recursosh01
VENTAS_PASSWORD=ventas2024
SOPORTE_PASSWORD=soporte01
